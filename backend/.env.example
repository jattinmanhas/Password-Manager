APP_ENV=dev
APP_PORT=8080
APP_READ_TIMEOUT=10s
APP_WRITE_TIMEOUT=15s
APP_IDLE_TIMEOUT=60s

DATABASE_URL=postgres://pmv2:pmv2_dev_password@postgres:5432/pmv2?sslmode=disable
SESSION_TTL=720h
AUTH_TOKEN_PEPPER=pmv2-dev-pepper-change-me
TOTP_ISSUER=PMV2
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=pmv2_session

# Logging
# LOG_LEVEL: debug | info | warn | error  (default: info)
LOG_LEVEL=info
# LOG_FORMAT: text (human-readable) | json (structured, recommended for prod)
LOG_FORMAT=text
# Path to log file (relative to binary working directory)
LOG_FILE_PATH=logs/api.log
# Max size of a single log file in MB before it is rotated
LOG_MAX_SIZE_MB=100
# Max number of rotated backup files to keep
LOG_MAX_BACKUPS=10
# Delete rotated log files older than this many days (28 days retention)
LOG_MAX_AGE_DAYS=28
