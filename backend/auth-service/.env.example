# Server Configuration
PORT=3001
ENVIRONMENT=development

# JWT Configuration
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRY_HOURS=24

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=pm_user
DB_PASSWORD=pm_password
DB_NAME=password_manager
DB_SSLMODE=disable

# Encryption
PBKDF2_ITERATIONS=100000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=60

# Password Reset
RESET_TOKEN_EXPIRY_MINUTES=30

# Email Configuration (Optional - for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Bcrypt Configuration
BCRYPT_COST=12
